generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  FOLLOW_UP
  PAYMENT_PENDING
  CONVERTED
  NOT_INTERESTED
  LOST
}

enum CustomerType {
  VIP_SIGNALS
  COPY_TRADING
  INSTANT_FUNDED
  EVALUATION
  PERSONAL_ACCOUNT
}

enum CustomerStatus {
  ACTIVE
  PENDING_SETUP
  SUSPENDED
  PAUSED
  COMPLETED
  FUNDED
  CANCELLED
  LOST
}

enum AccountPlatform {
  MT4
  MT5
  TRADELOCKER
  OTHER
}

enum ApplicationStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
  CONVERTED
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String             @id @default(cuid())
  name         String
  email        String             @unique
  passwordHash String
  role         UserRole           @default(STAFF)
  assignedLeads Lead[]            @relation("AssignedLead")
  activityLogs ActivityLog[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Lead {
  id              String             @id @default(cuid())
  fullName        String
  email           String             @unique
  phone           String?
  whatsapp        String?
  country         String?
  city            String?
  serviceInterest String
  leadSource      String?
  campaign        String?
  status          LeadStatus          @default(NEW)
  assignedToId    String?
  assignedTo      User?               @relation("AssignedLead", fields: [assignedToId], references: [id])
  notes           String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  activityLogs    ActivityLog[]
  communications  CommunicationLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Customer {
  id                 String             @id @default(cuid())
  fullName           String
  email              String             @unique
  phone              String?
  whatsapp           String?
  country            String?
  city               String?
  customerType       CustomerType
  accountPlatform    AccountPlatform?
  brokerOrPropFirm   String?
  accountLogin       String?
  initialCapital     Decimal            @default(0)
  currentBalance     Decimal            @default(0)
  currentEquity      Decimal            @default(0)
  status             CustomerStatus      @default(PENDING_SETUP)
  startDate          DateTime?
  renewalDate        DateTime?
  profitShareTier    String?
  setupFeeStatus     String?
  notes              String?
  activityLogs       ActivityLog[]
  communications     CommunicationLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Application {
  id                String             @id @default(cuid())
  fullName          String
  email             String
  phone             String?
  whatsapp          String?
  country           String?
  city              String?
  service           String
  accountSize       String?
  startingCapital   String?
  propFirm          String?
  broker            String?
  tradingExperience String?
  message           String?
  status            ApplicationStatus  @default(NEW)
  activityLogs      ActivityLog[]
  communications    CommunicationLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ActivityLog {
  id            String       @id @default(cuid())
  type          String
  description   String
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())
}

model CommunicationLog {
  id            String              @id @default(cuid())
  channel       CommunicationChannel
  recipient     String
  subject       String?
  message       String
  status        CommunicationStatus @default(PENDING)
  leadId        String?
  lead          Lead?               @relation(fields: [leadId], references: [id])
  customerId    String?
  customer      Customer?           @relation(fields: [customerId], references: [id])
  applicationId String?
  application   Application?        @relation(fields: [applicationId], references: [id])
  createdAt     DateTime            @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
