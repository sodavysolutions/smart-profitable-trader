generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  FOLLOW_UP
  PAYMENT_PENDING
  CONVERTED
  NOT_INTERESTED
  LOST
}

enum CustomerType {
  VIP_SIGNALS
  COPY_TRADING
  INSTANT_FUNDED
  EVALUATION
  PERSONAL_ACCOUNT
}

enum CustomerStatus {
  ACTIVE
  PENDING_SETUP
  SUSPENDED
  PAUSED
  COMPLETED
  FUNDED
  CANCELLED
  LOST
}

enum AccountPlatform {
  MT4
  MT5
  TRADELOCKER
  OTHER
}

enum ApplicationStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
  CONVERTED
}

enum SubscriptionType {
  CUSTOMER_SUBSCRIPTION
  BUSINESS_EXPENSE
}

enum BillingCycle {
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  UPCOMING
  OVERDUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_PAID
}

enum ExpensePaymentStatus {
  PAID
  UPCOMING
  OVERDUE
  CANCELLED
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
}

enum ProfitShareStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  DISPUTED
  CANCELLED
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  role         UserRole        @default(STAFF)
  assignedLeads Lead[]         @relation("AssignedLead")
  activityLogs ActivityLog[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Lead {
  id              String             @id @default(cuid())
  fullName        String
  email           String             @unique
  phone           String?
  whatsapp        String?
  country         String?
  city            String?
  serviceInterest String
  leadSource      String?
  campaign        String?
  status          LeadStatus         @default(NEW)
  assignedToId    String?
  assignedTo      User?              @relation("AssignedLead", fields: [assignedToId], references: [id])
  notes           String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  activityLogs    ActivityLog[]
  communications  CommunicationLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Customer {
  id               String             @id @default(cuid())
  fullName         String
  email            String             @unique
  phone            String?
  whatsapp         String?
  dateOfBirth      DateTime?
  country          String?
  city             String?
  customerType     CustomerType
  accountPlatform  AccountPlatform?
  brokerOrPropFirm String?
  accountLogin     String?
  initialCapital   Decimal            @default(0)
  currentBalance   Decimal            @default(0)
  currentEquity    Decimal            @default(0)
  status           CustomerStatus     @default(PENDING_SETUP)
  startDate        DateTime?
  renewalDate      DateTime?
  profitShareTier  String?
  setupFeeStatus   String?
  notes            String?
  subscriptions    Subscription[]
  payments         Payment[]
  profitShares     ProfitShare[]
  accountProgress  AccountProgress[]
  activityLogs     ActivityLog[]
  communications   CommunicationLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Application {
  id                String            @id @default(cuid())
  fullName          String
  email             String
  phone             String?
  whatsapp          String?
  country           String?
  city              String?
  service           String
  accountSize       String?
  startingCapital   String?
  propFirm          String?
  broker            String?
  tradingExperience String?
  message           String?
  status            ApplicationStatus @default(NEW)
  activityLogs      ActivityLog[]
  communications    CommunicationLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Subscription {
  id              String             @id @default(cuid())
  name            String
  type            SubscriptionType
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  expenseId       String?            @unique
  expense         Expense?           @relation(fields: [expenseId], references: [id])
  relatedName     String?
  amount          Decimal            @default(0)
  currency        String             @default("USD")
  startDate       DateTime?
  renewalDate     DateTime?
  billingCycle    BillingCycle       @default(MONTHLY)
  status          SubscriptionStatus @default(ACTIVE)
  reminderEnabled Boolean            @default(true)
  notes           String?
  activityLogs    ActivityLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Payment {
  id               String         @id @default(cuid())
  customerId       String?
  customer         Customer?      @relation(fields: [customerId], references: [id])
  serviceType      String
  amount           Decimal        @default(0)
  currency         String         @default("USD")
  paymentDate      DateTime?
  paymentMethod    String?
  status           PaymentStatus  @default(PENDING)
  invoiceReference String?
  notes            String?
  activityLogs     ActivityLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Expense {
  id            String               @id @default(cuid())
  name          String
  category      String
  amount        Decimal              @default(0)
  currency      String               @default("USD")
  billingCycle  BillingCycle         @default(MONTHLY)
  dueDate       DateTime?
  renewalDate   DateTime?
  paymentStatus ExpensePaymentStatus @default(UPCOMING)
  paymentMethod String?
  vendor        String?
  notes         String?
  subscription  Subscription?
  activityLogs  ActivityLog[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model ProfitShare {
  id                String            @id @default(cuid())
  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])
  totalProfit       Decimal           @default(0)
  clientPercentage  Decimal           @default(65)
  companyPercentage Decimal           @default(35)
  clientShare       Decimal           @default(0)
  companyShare      Decimal           @default(0)
  amountPaid        Decimal           @default(0)
  amountPending     Decimal           @default(0)
  paymentDate       DateTime?
  status            ProfitShareStatus @default(PENDING)
  notes             String?
  activityLogs      ActivityLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model AccountProgress {
  id                String         @id @default(cuid())
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id])
  serviceType       CustomerType
  phase             String?
  accountSize       Decimal        @default(0)
  currentBalance    Decimal        @default(0)
  currentEquity     Decimal        @default(0)
  profitTarget      Decimal        @default(0)
  currentProfit     Decimal        @default(0)
  growthPercentage  Decimal        @default(0)
  drawdownLimit     Decimal        @default(0)
  currentDrawdown   Decimal        @default(0)
  dailyDrawdown     Decimal        @default(0)
  maxDrawdown       Decimal        @default(0)
  daysTraded        Int            @default(0)
  minimumTradeDays  Int            @default(0)
  status            String
  notes             String?
  activityLogs      ActivityLog[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model ActivityLog {
  id            String       @id @default(cuid())
  type          String
  description   String
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentId      String?
  payment        Payment?    @relation(fields: [paymentId], references: [id])
  expenseId      String?
  expense        Expense?    @relation(fields: [expenseId], references: [id])
  profitShareId  String?
  profitShare    ProfitShare? @relation(fields: [profitShareId], references: [id])
  accountProgressId String?
  accountProgress   AccountProgress? @relation(fields: [accountProgressId], references: [id])
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())
}

model CommunicationLog {
  id            String              @id @default(cuid())
  channel       CommunicationChannel
  recipient     String
  subject       String?
  message       String
  status        CommunicationStatus @default(PENDING)
  leadId        String?
  lead          Lead?               @relation(fields: [leadId], references: [id])
  customerId    String?
  customer      Customer?           @relation(fields: [customerId], references: [id])
  applicationId String?
  application   Application?        @relation(fields: [applicationId], references: [id])
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
